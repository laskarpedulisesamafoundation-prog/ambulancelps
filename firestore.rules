rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validations for Patient
    function isValidPatient(data) {
      return data.nama is string && data.nama.size() > 0 && data.nama.size() <= 200
          && data.alamat is string && data.alamat.size() > 0 && data.alamat.size() <= 500
          && data.telepon is string && data.telepon.size() <= 50
          && data.kategoriStatus is string && data.kategoriStatus.size() <= 100;
    }

    // Validations for Trip
    function isValidTrip(data) {
      return data.namaPasien is string && data.namaPasien.size() > 0 && data.namaPasien.size() <= 200
          && data.tujuan is string && data.tujuan.size() > 0 && data.tujuan.size() <= 500
          && data.tanggal is string && data.tanggal.size() == 10
          && data.supir is string && data.supir.size() > 0 && data.supir.size() <= 200
          && data.kmSebelum is number && data.kmSebelum >= 0
          && data.status is string && (data.status == 'dalam_perjalanan' || data.status == 'selesai' || data.status == 'batal');
    }

    // Validations for Expense
    function isValidExpense(data) {
      return data.kategori is string && (data.kategori == 'bensin' || data.kategori == 'tol' || data.kategori == 'makan' || data.kategori == 'servis_ambulance' || data.kategori == 'lainnya')
          && data.jumlah is number && data.jumlah >= 0
          && data.keterangan is string && data.keterangan.size() <= 500
          && data.tanggal is string && data.tanggal.size() == 10;
    }

    // Patients Collection Rules
    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && isValidId(patientId);
      allow create, update: if isSignedIn() && isValidId(patientId) && isValidPatient(request.resource.data);
    }

    // Trips Collection Rules
    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && isValidId(tripId);
      allow create, update: if isSignedIn() && isValidId(tripId) && isValidTrip(request.resource.data);
    }

    // Expenses Collection Rules
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow delete: if isSignedIn() && isValidId(expenseId);
      allow create, update: if isSignedIn() && isValidId(expenseId) && isValidExpense(request.resource.data);
    }

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
